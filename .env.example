# Anthropic API key. If unset, the service uses the deterministic MockLLMClient.
ANTHROPIC_API_KEY=

# Override to "claude" to force the real client even if the key is short.
# Default: auto (real if ANTHROPIC_API_KEY is set, mock otherwise)
LLM_BACKEND=auto

# Which Claude model to use when LLM_BACKEND resolves to "claude".
ANTHROPIC_MODEL=claude-sonnet-4-6
